<resources>
    <style name="Theme.KgsCalendar" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/launcher_fg</item>
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="WidgetMonthDynamicChipContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">14dp</item>
        <item name="android:layout_marginTop">1dp</item>
        <item name="android:visibility">gone</item>
    </style>

    <style name="WidgetMonthDynamicChipText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:ellipsize">none</item>
        <item name="android:fadingEdgeLength">6dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:requiresFadingEdge">horizontal</item>
        <item name="android:scrollHorizontally">true</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="WidgetMonthDot">
        <item name="android:layout_width">10dp</item>
        <item name="android:layout_height">9dp</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:scaleType">center</item>
        <item name="android:visibility">gone</item>
    </style>
</resources>
