<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_task_root"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/widget_item_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingEnd="8dp">

    <TextView
        android:id="@+id/widget_task_accent"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:text=""
        android:background="#2563A8" />

    <TextView
        android:id="@+id/widget_task_status"
        android:layout_width="30dp"
        android:layout_height="match_parent"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="#526173"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="2dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="#17202A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widget_task_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#526173"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_task_subtasks"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="#2563A8"
        android:textSize="11sp"
        android:visibility="gone" />
</LinearLayout>
