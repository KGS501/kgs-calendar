<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_month_day_root"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_margin="1dp"
    android:layout_weight="1"
    android:background="@drawable/widget_month_day_background"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="1dp">

    <TextView
        android:id="@+id/widget_month_day_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="#17202A"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_month_markers"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="#2563A8"
        android:textSize="10sp" />
</LinearLayout>
